# API Configuration
VITE_API_URL="http://localhost:3001/api"

# Stripe Configuration (Test Mode)
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-test-publishable-key"

# Google OAuth
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# App Configuration
VITE_APP_NAME="P2P Betting Platform"
VITE_APP_VERSION="1.0.0"
VITE_APP_DESCRIPTION="Private P2P Sports Betting Platform"

# Feature Flags
VITE_ENABLE_STRIPE=true
VITE_ENABLE_MPESA=true
VITE_ENABLE_GOOGLE_AUTH=true

# Environment
VITE_NODE_ENV="development"
